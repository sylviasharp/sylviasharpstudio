---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Sylvia Sharp Studio">
  <h1 style="font-size: 2.5rem; margin-bottom: 1rem;">About Sylvia Sharp Studio</h1>
  
  <p style="font-size: 1.1rem; line-height: 1.8; color: #555; margin-bottom: 2rem; max-width: 800px;">
    Welcome! I'm Sylvia, a content creator and marketing strategist passionate about helping businesses tell their stories and connect with their audiences.
  </p>

  <h2 style="font-size: 1.8rem; margin-top: 2rem; margin-bottom: 1rem;">What I Do</h2>
  <p style="line-height: 1.8; color: #555; margin-bottom: 2rem; max-width: 800px;">
    I specialize in creating compelling content and developing marketing strategies that drive engagement and growth. Whether you need blog posts, social media content, or a comprehensive marketing plan, I'm here to help.
  </p>

  <h2 style="font-size: 1.8rem; margin-top: 2rem; margin-bottom: 1rem;">Get In Touch</h2>
  <p style="line-height: 1.8; color: #555; max-width: 800px;">
    Ready to work together? <a href="mailto:contact@sylviasharpstudio.com">Send me an email</a> or reach out on social media.
  </p>
</Layout>
